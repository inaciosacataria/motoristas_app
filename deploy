#!/bin/bash

# Script de Deploy para cPanel/Hosting Compartilhado
# Copia todo o conteГєdo da pasta public para a raiz (necessГЎrio em cPanel)
# Uso: ./deploy
# Nota: NГЈo requer sudo - adequado para hosting compartilhado

set -e  # Para o script se houver erro

# -------- ConfiguraГ§Гµes --------
BRANCH="${BRANCH:-main}"  # Pode ser sobrescrito por variГЎvel de ambiente

# Cores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${GREEN}рџљЂ Iniciando deploy para cPanel/hosting compartilhado...${NC}"
echo ""

# Verifica se estamos no diretГіrio correto
if [ ! -d "public" ]; then
    echo -e "${RED}вќЊ Erro: Pasta 'public' nГЈo encontrada!${NC}"
    echo "Execute este script a partir do diretГіrio raiz do projeto Laravel."
    exit 1
fi

PROJECT_ROOT="$(pwd)"
ENV_FILE="$PROJECT_ROOT/.env"

# -------- 1. Backup do .env --------
if [ -f "$ENV_FILE" ]; then
    echo -e "${YELLOW}рџ”’ Fazendo backup do .env...${NC}"
    cp "$ENV_FILE" "$PROJECT_ROOT/.env.backup"
    echo -e "${GREEN}вњ“ Backup do .env criado${NC}"
else
    echo -e "${YELLOW}вљ пёЏ  Arquivo .env nГЈo encontrado${NC}"
fi
echo ""

# -------- 2. Atualizar cГіdigo --------
echo -e "${YELLOW}рџ“Ґ Atualizando cГіdigo do repositГіrio...${NC}"
if [ -d ".git" ]; then
    echo -e "${BLUE}  в†’ Executando git fetch...${NC}"
    git fetch origin || {
        echo -e "${YELLOW}вљ пёЏ  Aviso: git fetch falhou${NC}"
    }

    echo -e "${BLUE}  в†’ Executando git reset --hard origin/$BRANCH...${NC}"
    git reset --hard "origin/$BRANCH" || {
        echo -e "${YELLOW}вљ пёЏ  Aviso: git reset falhou, tentando git pull...${NC}"
        git pull || {
            echo -e "${YELLOW}вљ пёЏ  Aviso: git pull tambГ©m falhou, continuando...${NC}"
        }
    }
    echo -e "${GREEN}вњ“ CГіdigo atualizado${NC}"
else
    echo -e "${YELLOW}вљ пёЏ  DiretГіrio .git nГЈo encontrado, pulando atualizaГ§ГЈo${NC}"
fi
echo ""

# -------- 3. Restaurar .env --------
if [ -f "$PROJECT_ROOT/.env.backup" ]; then
    echo -e "${YELLOW}в™»пёЏ  Restaurando .env...${NC}"
    mv "$PROJECT_ROOT/.env.backup" "$ENV_FILE"
    echo -e "${GREEN}вњ“ .env restaurado${NC}"
fi
echo ""

# -------- 4. Verificar versГЈo do PHP --------
echo -e "${YELLOW}рџ”Ќ Verificando versГЈo do PHP...${NC}"
PHP_VERSION=$(php -r "echo PHP_VERSION;" 2>/dev/null || echo "unknown")
echo -e "${BLUE}  в†’ VersГЈo do PHP: $PHP_VERSION${NC}"

# Tenta encontrar PHP 8.2 ou superior no cPanel
PHP82_PATH=""
for php_path in /opt/cpanel/ea-php82/root/usr/bin/php /usr/local/bin/php82 /usr/bin/php82 php82; do
    if command -v "$php_path" &> /dev/null; then
        PHP82_VERSION=$($php_path -r "echo PHP_VERSION;" 2>/dev/null)
        if [ -n "$PHP82_VERSION" ]; then
            PHP82_PATH="$php_path"
            echo -e "${GREEN}  вњ“ PHP 8.2+ encontrado: $php_path ($PHP82_VERSION)${NC}"
            break
        fi
    fi
done

# Se nГЈo encontrou PHP 8.2+, tenta PHP 8.1
if [ -z "$PHP82_PATH" ]; then
    for php_path in /opt/cpanel/ea-php81/root/usr/bin/php /usr/local/bin/php81 /usr/bin/php81 php81; do
        if command -v "$php_path" &> /dev/null; then
            PHP81_VERSION=$($php_path -r "echo PHP_VERSION;" 2>/dev/null)
            if [ -n "$PHP81_VERSION" ]; then
                PHP82_PATH="$php_path"
                echo -e "${YELLOW}  вљ пёЏ  PHP 8.1 encontrado: $php_path ($PHP81_VERSION)${NC}"
                break
            fi
        fi
    done
fi

# Define qual PHP usar
if [ -n "$PHP82_PATH" ]; then
    PHP_CMD="$PHP82_PATH"
    echo -e "${GREEN}  в†’ Usando: $PHP_CMD${NC}"
else
    PHP_CMD="php"
    echo -e "${YELLOW}  вљ пёЏ  Usando PHP padrГЈo do sistema${NC}"
fi
echo ""

# -------- 5. DependГЄncias --------
echo -e "${YELLOW}рџ“¦ Instalando dependГЄncias...${NC}"
if command -v composer &> /dev/null; then
    $PHP_CMD $(command -v composer) install --no-dev --optimize-autoloader --no-interaction || {
        echo -e "${YELLOW}вљ пёЏ  composer install falhou, tentando com php composer.phar...${NC}"
        if [ -f "composer.phar" ]; then
            $PHP_CMD composer.phar install --no-dev --optimize-autoloader --no-interaction || true
        elif [ -f "$HOME/composer.phar" ]; then
            $PHP_CMD "$HOME/composer.phar" install --no-dev --optimize-autoloader --no-interaction || true
        else
            echo -e "${YELLOW}вљ пёЏ  Composer nГЈo encontrado, pulando instalaГ§ГЈo de dependГЄncias${NC}"
        fi
    }
    echo -e "${GREEN}вњ“ DependГЄncias instaladas${NC}"
else
    if [ -f "composer.phar" ]; then
        $PHP_CMD composer.phar install --no-dev --optimize-autoloader --no-interaction || true
        echo -e "${GREEN}вњ“ DependГЄncias instaladas${NC}"
    elif [ -f "$HOME/composer.phar" ]; then
        $PHP_CMD "$HOME/composer.phar" install --no-dev --optimize-autoloader --no-interaction || true
        echo -e "${GREEN}вњ“ DependГЄncias instaladas${NC}"
    else
        echo -e "${YELLOW}вљ пёЏ  Composer nГЈo encontrado, pulando instalaГ§ГЈo de dependГЄncias${NC}"
    fi
fi
echo ""

# -------- 6. PermissГµes --------
echo -e "${YELLOW}рџ”ђ Ajustando permissГµes...${NC}"
if [ -d "storage" ]; then
    chmod -R 775 storage 2>/dev/null || chmod -R 755 storage
    echo -e "${GREEN}вњ“ PermissГµes do storage ajustadas${NC}"
fi

if [ -d "bootstrap/cache" ]; then
    chmod -R 775 bootstrap/cache 2>/dev/null || chmod -R 755 bootstrap/cache
    echo -e "${GREEN}вњ“ PermissГµes do bootstrap/cache ajustadas${NC}"
fi
echo ""

# -------- 7. Migrations (Opcional - DESABILITADO por seguranГ§a) --------
# вљ пёЏ  ATENГ‡ГѓO: Executar migrations pode modificar a estrutura do banco de dados
# Para habilitar: RUN_MIGRATIONS=true ./deploy
# RECOMENDAГ‡ГѓO: Execute migrations manualmente apГіs backup do banco.

MIGRATIONS_RAN="nГЈo"
if [ "${RUN_MIGRATIONS:-false}" = "true" ]; then
    echo -e "${RED}вљ пёЏ  ATENГ‡ГѓO: Executando migrations!${NC}"
    echo -e "${YELLOW}   Certifique-se de ter feito backup do banco de dados!${NC}"
    echo -e "${BLUE}   Pressione Ctrl+C para cancelar (aguardando 5 segundos)...${NC}"
    sleep 5

    echo -e "${YELLOW}рџ—„пёЏ  Rodando migrations...${NC}"
    $PHP_CMD artisan migrate --force 2>&1 || true
    echo -e "${GREEN}вњ“ Migrations processadas${NC}"
    MIGRATIONS_RAN="sim"
else
    echo -e "${YELLOW}рџ—„пёЏ  Migrations puladas por seguranГ§a (padrГЈo)${NC}"
    echo -e "${BLUE}  в†’ Para executar: RUN_MIGRATIONS=true ./deploy${NC}"
fi
echo ""

# -------- 8. Cache --------
echo -e "${YELLOW}рџ§№ Limpando e criando cache...${NC}"
$PHP_CMD artisan config:clear 2>/dev/null || true
$PHP_CMD artisan route:clear 2>/dev/null || true
$PHP_CMD artisan view:clear 2>/dev/null || true
$PHP_CMD artisan config:cache 2>/dev/null || true
$PHP_CMD artisan route:cache 2>/dev/null || true
$PHP_CMD artisan view:cache 2>/dev/null || true
echo -e "${GREEN}вњ“ Cache atualizado${NC}"
echo ""

# -------- 9. Backup de arquivos importantes --------
BACKUP_DIR="backup_$(date +%Y%m%d_%H%M%S)"
echo -e "${YELLOW}рџ“¦ Criando backup de arquivos importantes...${NC}"
mkdir -p "$BACKUP_DIR"

if [ -f "index.php" ]; then
    cp index.php "$BACKUP_DIR/index.php.backup"
    echo -e "${BLUE}  в†’ Backup de index.php criado${NC}"
fi
if [ -f ".htaccess" ]; then
    cp .htaccess "$BACKUP_DIR/.htaccess.backup"
    echo -e "${BLUE}  в†’ Backup de .htaccess criado${NC}"
fi
if [ -f "public/.htaccess" ]; then
    cp public/.htaccess "$BACKUP_DIR/public.htaccess.backup"
    echo -e "${BLUE}  в†’ Backup de public/.htaccess criado${NC}"
fi
echo -e "${GREEN}вњ“ Backup criado em: $BACKUP_DIR${NC}"
echo ""

# -------- 10. Copiar .htaccess da public se nГЈo existir no root --------
if [ -f "public/.htaccess" ] && [ ! -f ".htaccess" ]; then
    echo -e "${YELLOW}рџ“„ Copiando .htaccess da pasta public...${NC}"
    cp public/.htaccess .htaccess
    echo -e "${GREEN}вњ“ .htaccess copiado${NC}"
elif [ -f "public/.htaccess" ] && [ -f ".htaccess" ]; then
    echo -e "${YELLOW}вљ пёЏ  .htaccess jГЎ existe no root, mantendo o existente${NC}"
fi
echo ""

# -------- 11. Copiar todo o conteГєdo da pasta public para a raiz --------
echo -e "${YELLOW}рџ“‚ Copiando todo o conteГєdo da pasta public para a raiz...${NC}"

cd public
for item in * .[!.]* ..?*; do
    [ -e "$item" ] || [ -L "$item" ] || continue
    if [ -f "$item" ]; then
        if [ "$item" = ".htaccess" ] && [ -f "../.htaccess" ]; then
            echo -e "${BLUE}  в†’ Pulando .htaccess (jГЎ existe no root)${NC}"
            continue
        fi
        echo -e "${BLUE}  в†’ Copiando arquivo: $item${NC}"
        cp -f "$item" "../"
    elif [ -d "$item" ]; then
        echo -e "${BLUE}  в†’ Copiando pasta: $item${NC}"
        mkdir -p "../$item"
        cp -r "$item"/* "../$item/" 2>/dev/null || true
    fi
done
cd ..

# Verifica se o index.php estГЎ no root e ajusta caminhos
if [ -f "index.php" ]; then
    echo -e "${GREEN}вњ“ index.php no root${NC}"

    echo -e "${YELLOW}рџ”§ Ajustando caminhos no index.php (public в†’ root)...${NC}"
    cp index.php index.php.before_fix

    # Corrige caminhos: __DIR__.'/../vendor' -> __DIR__.'/vendor'
    if sed --version 2>/dev/null | grep -q GNU; then
        sed -i "s|__DIR__\.'/\.\./vendor|__DIR__.'/vendor|g" index.php
        sed -i "s|__DIR__\.'/\.\./bootstrap|__DIR__.'/bootstrap|g" index.php
        sed -i "s|__DIR__\.'/\.\./storage|__DIR__.'/storage|g" index.php
    else
        # macOS / BSD sed
        sed -i '' "s|__DIR__\.'/\.\./vendor|__DIR__.'/vendor|g" index.php
        sed -i '' "s|__DIR__\.'/\.\./bootstrap|__DIR__.'/bootstrap|g" index.php
        sed -i '' "s|__DIR__\.'/\.\./storage|__DIR__.'/storage|g" index.php
    fi

    if grep -q "__DIR__.'/vendor" index.php && grep -q "__DIR__.'/bootstrap" index.php; then
        echo -e "${GREEN}вњ“ Caminhos no index.php ajustados${NC}"
        rm -f index.php.before_fix
    else
        echo -e "${RED}вќЊ Erro ao ajustar caminhos, restaurando backup...${NC}"
        mv index.php.before_fix index.php
    fi
else
    echo -e "${RED}вќЊ Erro: index.php nГЈo encontrado no root!${NC}"
    exit 1
fi

if [ -f ".htaccess" ]; then
    echo -e "${GREEN}вњ“ .htaccess configurado no root${NC}"
    if grep -q "RewriteRule.*index.php" .htaccess; then
        echo -e "${GREEN}вњ“ .htaccess contГ©m regras do Laravel${NC}"
    fi
else
    echo -e "${YELLOW}вљ пёЏ  .htaccess nГЈo encontrado - pode ser necessГЎrio criar manualmente${NC}"
fi
echo ""

# -------- Resumo Final --------
echo ""
echo -e "${GREEN}вњ… Deploy concluГ­do com sucesso!${NC}"
echo ""
echo -e "${BLUE}рџ“‹ Resumo:${NC}"
echo "  вњ“ CГіdigo atualizado do repositГіrio"
echo "  вњ“ .env preservado"
echo "  вњ“ DependГЄncias instaladas"
echo "  вњ“ PermissГµes ajustadas"
echo "  вњ“ Migrations: $MIGRATIONS_RAN"
echo "  вњ“ Cache atualizado"
echo "  вњ“ ConteГєdo da pasta public copiado para a raiz"
echo "  вњ“ index.php configurado no root"
echo "  вњ“ .htaccess configurado no root"
echo "  вњ“ Backup em: $BACKUP_DIR"
echo ""
echo -e "${GREEN}рџЊђ AplicaГ§ГЈo pronta para ser servida a partir do root (cPanel).${NC}"
echo ""
